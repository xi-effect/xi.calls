# Локальная демка ВКС без xi.tutor API — скопируйте в .env.local

VITE_LIVEKIT_DEV_MODE=true
VITE_LIVEKIT_DEV_TOKEN=<jwt от livekit-server --dev>
VITE_SERVER_URL_LIVEKIT_DEV=ws://127.0.0.1:7880

# Бэкенд xi.tutor не используется; можно оставить пустым или localhost
VITE_SERVER_URL_BACKEND=http://localhost:3000
VITE_SERVER_URL_SOCKETIO=http://localhost:3000
